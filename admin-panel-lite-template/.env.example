# =================================================================
# ADMIN PANEL LITE — environment template
# Copy to `.env` and fill in YOUR values. NEVER commit `.env` to git.
# =================================================================

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Hardcoded canonical hostname for production HTTPS redirect and
# for the URL that goes inside password-change emails. Without this,
# the server refuses to start in production (Host-header injection
# is blocked at the source).
PUBLIC_HOSTNAME=

# Trust proxy (1 = trust the first hop). Set to 1 only when actually
# behind a proxy (Cloudflare, Railway, nginx). Set to false in dev.
# Defaults: production → 1, development → false.
# TRUST_PROXY=1

# ── Auth ──────────────────────────────────────────────────────────
# 64+ random characters. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Default password used on first run (and only the first run). The
# admin must change it via the panel before doing anything else.
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# Random secret protecting unauthenticated server-to-server endpoints
# (e.g. /api/submissions/list for an internal CRM importer).
ADMIN_API_KEY=

# ── PostgreSQL (optional) ─────────────────────────────────────────
# When set, credentials and submissions go to Postgres. When unset,
# the panel falls back to JSON files (fine for single-instance dev,
# bad for multi-instance / ephemeral hosting like Railway).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── SMTP (Gmail App Password recommended) ─────────────────────────
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5
