generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Organisation ─────────────────────────────────────────────────────────────

model Organisation {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  jobDescriptions      JobDescription[]
  templates            Template[]
  orgCharts            OrgChart[]
  batchExports         BatchExport[]
  processes            Process[]
  processRoles         ProcessRole[]
  payGroups            PayGroup[]
  jobFamilies          JobFamily[]
  jobArchitectureSlots JobArchitectureSlot[]

  @@map("organisations")
}

// ── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships      Membership[]
  ownedJDs         JobDescription[] @relation("JDOwner")
  jdVersions       JDVersion[]
  comments         JDComment[]
  createdTokens    GuestToken[]     @relation("TokenCreator")
  resolvedComments JDComment[]      @relation("CommentResolver")
  createdTemplates Template[]
  exports          Export[]
  batchExports     BatchExport[]
  evalResults      EvalResult[]
  accounts         Account[]
  sessions         Session[]

  @@map("users")
}

// ── Auth.js Models ───────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Membership (User <-> Organisation) ───────────────────────────────────────

enum OrgRole {
  ADMIN
  OWNER
  MEMBER
}

model Membership {
  id     String  @id @default(uuid())
  userId String
  orgId  String
  role   OrgRole @default(MEMBER)

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("memberships")
}

// ── Job Description ──────────────────────────────────────────────────────────

enum JDStatus {
  DRAFT
  UNDER_REVISION
  APPROVED
  ARCHIVED
}

model JobDescription {
  id         String   @id @default(uuid())
  orgId      String
  ownerId    String
  templateId String?
  data       Json     @default("{}")
  status     JDStatus @default(DRAFT)
  jobTitle   String   @default("")
  jobCode    String?
  orgUnit    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner    User         @relation("JDOwner", fields: [ownerId], references: [id])
  template Template?    @relation(fields: [templateId], references: [id])

  versions         JDVersion[]
  comments         JDComment[]
  guestTokens      GuestToken[]
  evalResults      EvalResult[]
  exports          Export[]
  payGroupMembers  PayGroupMember[]
  architectureSlot JobArchitectureSlot?

  @@index([orgId])
  @@index([ownerId])
  @@index([status])
  @@map("job_descriptions")
}

// ── JD Version (Immutable Audit Trail) ───────────────────────────────────────

enum ChangeType {
  FIELD_EDIT
  STATUS_CHANGE
  COMMENT
  IMPORT
  AI_ASSIST
  EVALUATION
  EXPORT
}

model JDVersion {
  id           String     @id @default(uuid())
  jdId         String
  authorId     String?
  authorType   String     @default("USER") // USER | GUEST
  data         Json?      // Full JD snapshot (optional, for major changes)
  changeType   ChangeType
  fieldChanged String?
  oldValue     String?
  newValue     String?
  note         String?
  timestamp    DateTime   @default(now())

  jd     JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
  author User?          @relation(fields: [authorId], references: [id])

  @@index([jdId])
  @@index([timestamp])
  @@map("jd_versions")
}

// ── JD Comment ───────────────────────────────────────────────────────────────

model JDComment {
  id           String    @id @default(uuid())
  jdId         String
  authorId     String?
  authorType   String    @default("USER") // USER | GUEST
  authorEmail  String?   // For guest comments
  content      String
  fieldId      String?   // Which field the comment is about (nullable = general)
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())

  jd         JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
  author     User?          @relation(fields: [authorId], references: [id])
  resolvedBy User?          @relation("CommentResolver", fields: [resolvedById], references: [id])

  @@index([jdId])
  @@map("jd_comments")
}

// ── Guest Token ──────────────────────────────────────────────────────────────

model GuestToken {
  id          String    @id @default(uuid())
  jdId        String
  createdById String
  email       String
  role        String    @default("VIEWER") // VIEWER | REVIEWER
  token       String    @unique @default(uuid())
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  jd        JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
  createdBy User           @relation("TokenCreator", fields: [createdById], references: [id])

  @@index([token])
  @@index([jdId])
  @@map("guest_tokens")
}

// ── Template ─────────────────────────────────────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  orgId       String?  // null = system template
  name        String
  purpose     String   @default("general")
  description String   @default("")
  sections    Json     // TemplateSection[]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  createdById String?

  org       Organisation?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User?            @relation(fields: [createdById], references: [id])
  jds       JobDescription[]

  @@index([orgId])
  @@map("templates")
}

// ── Evaluation Result ────────────────────────────────────────────────────────

model EvalResult {
  id           String   @id @default(uuid())
  jdId         String
  version      Int      @default(1)
  criteria     Json     // CriterionResult[]
  overallScore Int      @default(0)
  createdAt    DateTime @default(now())
  createdById  String?

  jd        JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
  createdBy User?          @relation(fields: [createdById], references: [id])

  @@index([jdId])
  @@map("eval_results")
}

// ── Export ────────────────────────────────────────────────────────────────────

model Export {
  id          String   @id @default(uuid())
  jdId        String
  userId      String
  format      String   // TXT | PDF | DOCX | MD | JSON
  downloadUrl String?
  createdAt   DateTime @default(now())

  jd   JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id])

  @@map("exports")
}

// ── Batch Export ─────────────────────────────────────────────────────────────

model BatchExport {
  id          String   @id @default(uuid())
  orgId       String
  userId      String
  jdIds       Json     // string[]
  format      String
  downloadUrl String?
  createdAt   DateTime @default(now())

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@map("batch_exports")
}

// ── Org Chart ────────────────────────────────────────────────────────────────

model OrgChart {
  id        String   @id @default(uuid())
  orgId     String
  nodes     Json     @default("[]") // positions, relationships
  updatedAt DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId])
  @@map("org_charts")
}

// ── Process Intelligence (RASCI) ─────────────────────────────────────────────

model Process {
  id        String   @id @default(uuid())
  orgId     String
  step      String
  rasci     Json     @default("{}") // { [role]: "R"|"A"|"S"|"C"|"I" }
  confirmed Boolean  @default(false)
  note      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("processes")
}

model ProcessRole {
  id    String @id @default(uuid())
  orgId String
  name  String

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@map("process_roles")
}

// ── Pay Groups (EUPTD 2023/970 Article 4) ────────────────────────────────────

model PayGroup {
  id          String   @id @default(uuid())
  orgId       String
  name        String   // e.g. "Pay Group A", "Senior Technical"
  description String?
  color       String   @default("#8A7560") // for visual distinction in matrix
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Organisation       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members  PayGroupMember[]
  auditLog PayGroupAuditLog[]

  @@index([orgId])
  @@map("pay_groups")
}

model PayGroupMember {
  id        String   @id @default(uuid())
  groupId   String
  jdId      String
  addedById String?
  addedAt   DateTime @default(now())

  group PayGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  jd    JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)

  @@unique([groupId, jdId])
  @@index([groupId])
  @@index([jdId])
  @@map("pay_group_members")
}

// Every action on a pay group is logged with a mandatory comment (Article 4 compliance)
model PayGroupAuditLog {
  id        String   @id @default(uuid())
  groupId   String
  jdId      String?  // Which JD was affected (null = group-level action)
  action    String   // GROUP_CREATED | JD_ADDED | JD_MOVED | JD_REMOVED | GROUP_RENAMED | AI_GROUPED
  fromGroup String?  // Previous group name (for moves)
  toGroup   String?  // New group name (for moves)
  comment   String   // MANDATORY comment explaining reason for change
  authorId  String?
  timestamp DateTime @default(now())

  group PayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([timestamp])
  @@map("pay_group_audit_log")
}

// ── Job Architecture Matrix ────────────────────────────────────────────────────

model JobFamily {
  id          String   @id @default(uuid())
  orgId       String
  name        String   // e.g. "Technology", "Sales", "Operations", "Finance"
  description String?
  color       String   @default("#8A7560")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  org   Organisation          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slots JobArchitectureSlot[]

  @@index([orgId])
  @@map("job_families")
}

model JobArchitectureSlot {
  id       String   @id @default(uuid())
  orgId    String
  familyId String
  jdId     String   @unique // One JD per slot in the matrix
  level    Int      // Grade level 1-20 (column in matrix)
  note     String?  // Optional placement note
  placedBy String?
  placedAt DateTime @default(now())

  org    Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  family JobFamily      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  jd     JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([familyId])
  @@map("job_architecture_slots")
}
